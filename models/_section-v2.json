{
    "definitions": [
        {
            "title": "Section",
            "id": "section",
            "plugins": {
                "xwalk": {
                    "page": {
                        "resourceType": "core/franklin/components/section/v1/section",
                        "template": {
                            "name": "Section",
                            "model": "section",
                            "style": "default",
                            "filter": "section"
                        }
                    }
                }
            }
        }
    ],
    "models": [
        {
            "id": "section",
            "fields": [
                {
                    "component": "text",
                    "name": "name",
                    "label": "Section Name",
                    "description": "The label shown for this section in the Content Tree"
                },
                {
                    "component": "select",
                    "name": "sectionType",
                    "label": "Section Type",
                    "valueType": "string",
                    "default": "default",
                    "value": "default",
                    "options": [
                        {
                            "name": "Default",
                            "value": "default"
                        },
                        {
                            "name": "Header",
                            "value": "header"
                        },
                        {
                            "name": "Footer",
                            "value": "footer"
                        },
                        {
                            "name": "Accordion",
                            "value": "accordion"
                        }
                    ]
                },
                {
                    "component": "multiselect",
                    "name": "styleDefault",
                    "label": "Style",
                    "valueType": "string[]",
                    "default": ["default"],
                    "condition": {
                        "===": [
                            {
                                "var": "sectionType"
                            },
                            "default"
                        ]
                    },
                    "options": [
                        {
                            "name": "Default",
                            "children": [
                                {
                                    "name": "Highlight",
                                    "value": "highlight"
                                },
                                {
                                    "name": "Blogs v1",
                                    "value": "blog-cards"
                                },
                                {
                                    "name": "Blogs v2",
                                    "value": "blog-cards2"
                                },
                                {
                                    "name": "Products Default",
                                    "value": "products"
                                },
                                {
                                    "name": "Products v1",
                                    "value": "product-variant1"
                                },
                                {
                                    "name": "Products v2",
                                    "value": "product-variant2"
                                },
                                {
                                    "name": "Products v3",
                                    "value": "product-variant3"
                                }
                            ]
                        }
                    ]
                },
                {
                    "component": "multiselect",
                    "name": "styleHeader",
                    "label": "Header Style",
                    "valueType": "string[]",
                    "condition": {
                        "===": [
                            {
                                "var": "sectionType"
                            },
                            "header"
                        ]
                    },
                    "options": [
                        {
                            "name": "Header",
                            "children": [
                                {
                                    "name": "Header Top",
                                    "value": "header-top"
                                },
                                {
                                    "name": "Header Menu",
                                    "value": "header-menu"
                                },
                                {
                                    "name": "Header Menu Body",
                                    "value": "header-menu-body"
                                },
                                {
                                    "name": "Header Variant 1",
                                    "value": "header-variant1"
                                },
                                {
                                    "name": "Header Variant 2",
                                    "value": "header-variant2"
                                },
                                {
                                    "name": "Header Variant 3",
                                    "value": "header-variant3"
                                }
                            ]
                        }
                    ]
                },
                {
                    "component": "multiselect",
                    "name": "styleFooter",
                    "label": "Footer Style",
                    "valueType": "string[]",
                    "condition": {
                        "===": [
                            {
                                "var": "sectionType"
                            },
                            "footer"
                        ]
                    },
                    "options": [
                        {
                            "name": "Footer",
                            "children": [
                                {
                                    "name": "Footer Main",
                                    "value": "footer-main"
                                },
                                {
                                    "name": "Footer Bottom",
                                    "value": "footer-bottom"
                                },
                                {
                                    "name": "Footer Variant 2",
                                    "value": "footer-variant2"
                                },
                                {
                                    "name": "Footer Variant 3",
                                    "value": "footer-variant3"
                                }
                            ]
                        }
                    ]
                },
                {
                    "component": "multiselect",
                    "name": "styleAccordion",
                    "label": "Accordion Style",
                    "valueType": "string[]",
                    "condition": {
                        "===": [
                            {
                                "var": "sectionType"
                            },
                            "accordion"
                        ]
                    },
                    "options": [
                        {
                            "name": "Accordion",
                            "children": [
                                {
                                    "name": "Accordion Variant 1",
                                    "value": "accordion-variant1"
                                },
                                {
                                    "name": "Accordion Variant 2",
                                    "value": "accordion-variant2"
                                },
                                {
                                    "name": "Accordion Variant 3",
                                    "value": "accordion-variant3"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "filters": [
        {
            "id": "section",
            "components": [
                "button",
                "cards",
                "carousel",
                "columns",
                "contentfragment",
                "css-variable",
                "dm-asset",
                "dm-template",
                "fragment",
                "hero",
                "iframe",
                "image",
                "search",
                "teaser",
                "text",
                "theme-configurator",
                "theme-preview",
                "title",
                "video",
                "trackrecord",
                "accordion",
                "tabs",
                "font-properties"
            ]
        }
    ]
}